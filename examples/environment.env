# ONDEWO S2T TypeScript client SDK — example configuration (TEMPLATE, no real secrets).
#
# Loaded by every example via dotenv, resolved relative to the script (see examples/ts-client.ts),
# so it works regardless of the current working directory. Copy your real values in locally; this
# file is committed as a template and MUST stay secret-free.

# --- Connection ---
ONDEWO_HOST=localhost
ONDEWO_PORT=8080

# --- Secure channel ---
# "true" selects https:// for the gRPC-web endpoint, "false" selects http://.
ONDEWO_USE_SECURE_CHANNEL=false

# --- Keycloak authentication (D18 headless-SDK login) ---
KEYCLOAK_URL=https://auth.ondewo.com/auth
KEYCLOAK_REALM=ondewo-ccai-platform
KEYCLOAK_CLIENT_ID=ondewo-nlu-cai-sdk-public
KEYCLOAK_USER_NAME=
KEYCLOAK_PASSWORD=
# "false" ONLY for a self-signed local Envoy; keep "true" everywhere else.
KEYCLOAK_VERIFY_SSL=true

# --- S2T service-specific ---
# Comma-separated language codes to filter pipelines by, e.g. "en-US,de-DE".
ONDEWO_S2T_LANGUAGES=en-US
